[user]
  name = Tom
  email = tomsturge+github@gmail.com

[core]
  editor = nvim
  pager = delta
  excludesfile = ~/.gitignore
  whitespace = space-before-tab,-indent-with-non-tab,trailing-space
  precomposeunicode = false

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true

[apply]
  whitespace = fix

[color]
  ui = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red
  new = green

[color "status"]
  added = yellow
  changed = green
  untracked = cyan

[help]
  autocorrect = 1

[merge]
  log = true
  conflictstyle = diff3

[push]
  default = current
  followTags = true

[diff]
  colorMoved = default
